    "build": "^0.1.4",
    "cron": "^4.4.0",
    "i18next": "^26.0.8",
    "jquery": "^4.0.0",
    "npm": "^11.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.15.0",
    "run": "^1.5.0",
    "tailwindcss": "^4.2.4",
    "usehooks-ts": "^3.1.0",
