{
  "name": "youtrack-issue-reminder",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --mode backend && vite build --mode workflows && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
